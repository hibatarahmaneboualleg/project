<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تسجيل الدخول | AgriFuture</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="https://cdn-icons-png.flaticon.com/512/2909/2909768.png">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap');
        * { font-family: 'Cairo', sans-serif; }

        :root {
            --primary-green: #27ae60;
            --light-green: #2ecc71;
        }

        body {
            background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
            min-height: 100vh;
        }

        .login-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }

        .btn-login {
            background: var(--primary-green);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
            width: 100%;
        }

        .btn-login:hover {
            background: #219a52;
            transform: translateY(-2px);
        }

        .input-field {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 16px;
            transition: all 0.3s;
            box-sizing: border-box;
        }

        .input-field:focus {
            outline: none;
            border-color: var(--primary-green);
            box-shadow: 0 0 0 3px rgba(39, 174, 96, 0.1);
        }

        .password-toggle {
            position: absolute;
            left: 14px;
            top: 42px;
            background: none;
            border: none;
            cursor: pointer;
            color: #666;
        }
    </style>
</head>
<body class="flex items-center justify-center p-4">
    <div class="login-card w-full max-w-md p-8">
        <!-- Logo -->
        <div class="text-center mb-8">
            <img src="https://cdn-icons-png.flaticon.com/512/2909/2909768.png" class="w-16 h-16 mx-auto mb-3" alt="AgriFuture">
            <h1 class="text-3xl font-black" style="color: var(--primary-green);">تسجيل الدخول</h1>
            <p class="text-gray-500 mt-1">مرحباً بعودتك إلى منصتك الذكية</p>
        </div>

        <!-- Form -->
        <form id="loginForm" class="space-y-5 text-right">
            <!-- Email -->
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-2">البريد الإلكتروني</label>
                <input type="email" id="loginEmail" class="input-field" placeholder="example@email.com" required>
            </div>

            <!-- Password -->
            <div class="relative">
                <label class="block text-sm font-bold text-gray-700 mb-2">كلمة المرور</label>
                <input type="password" id="loginPassword" class="input-field" placeholder="••••••••" required>
                <button type="button" class="password-toggle" onclick="togglePassword()">
                    <i class="fas fa-eye" id="toggleIcon"></i>
                </button>
            </div>

            <!-- Remember & Forgot -->
            <div class="flex justify-between items-center text-sm">
                <label class="flex items-center gap-2 text-gray-600 cursor-pointer">
                    <input type="checkbox" class="accent-green-600 w-4 h-4"> تذكرني
                </label>
                <a href="#" class="text-green-700 font-bold hover:underline">نسيت كلمة المرور؟</a>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt ml-2"></i> دخول
            </button>
        </form>

        <!-- Links -->
        <p class="text-center mt-6 text-gray-500">
            ليس لديك حساب؟
            <a href="register.html" class="text-green-700 font-bold hover:underline">إنشاء حساب جديد</a>
        </p>
        <a href="index.html" class="block text-center mt-3 text-gray-400 hover:text-green-600 text-sm">
            <i class="fas fa-arrow-right ml-1"></i> العودة للرئيسية
        </a>
    </div>

    <script src="assets/js/notifications.js"></script>
    <script>
        // Toggle Password Visibility
        function togglePassword() {
            const pw = document.getElementById('loginPassword');
            const icon = document.getElementById('toggleIcon');
            if (pw.type === 'password') {
                pw.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                pw.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        // Login Simulation
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;

            if (!email || !password) {
                showError('يرجى ملء جميع الحقول');
                return;
            }

            if (!email.includes('@')) {
                showError('البريد الإلكتروني غير صالح');
                return;
            }

            // Simulate login (accept any credentials for demo)
            const user = {
                name: email.split('@')[0],
                email: email,
                loggedIn: true
            };
            localStorage.setItem('agrifuture_user', JSON.stringify(user));

            showSuccess('تم تسجيل الدخول بنجاح');

            setTimeout(() => {
                window.location.href = 'dashboard.html';
            }, 2000);
        });
    </script>
</body>
</html>
